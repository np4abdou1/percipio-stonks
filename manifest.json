{
  "manifest_version": 3,
  "name": "Percipio Stonks",
  "version": "1.0",
  "description": "Automatically completes courses, knowledge checks, and assessments on Percipio",
  "icons": { "48": "icon.png", "128": "icon.png" },
  "host_permissions": [
    "https://ofppt.percipio.com/*"
  ],
  "content_scripts": [{
    "matches": ["https://ofppt.percipio.com/*"],
    "js": ["content.js"],
    "run_at": "document_end"
  }],
  "background": {
    "service_worker": "background.js"
  }
}
